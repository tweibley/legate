    javascript:
      document.addEventListener('DOMContentLoaded', () => {
        const $navbarBurgers = Array.prototype.slice.call(document.querySelectorAll('.navbar-burger'), 0);
        if ($navbarBurgers.length > 0) {
          $navbarBurgers.forEach( el => {
            el.addEventListener('click', () => {
              const target = el.dataset.target;
              const $target = document.getElementById(target);
              el.classList.toggle('is-active');
              $target.classList.toggle('is-active');
            });
          });
        }
      });

      window.codeMirrorInstances = window.codeMirrorInstances || {};

      function initCodeMirrorEditor(elementId, options = {}) {
        const editorElement = document.getElementById(elementId);
        if (editorElement && !window.codeMirrorInstances[elementId]) {
          console.log(`Initializing CodeMirror for #${elementId}`);
          try {
            const defaultOptions = {
              lineNumbers: true,
              mode: { name: "javascript", json: true },
              theme: "default",
              lineWrapping: true,
              gutters: ["CodeMirror-lint-markers"],
              lint: false,
              extraKeys: {"Ctrl-Q": function(cm){ cm.foldCode(cm.getCursor()); }, "Ctrl-Space": "autocomplete"},
              foldGutter: true,
              gutters: ["CodeMirror-linenumbers", "CodeMirror-foldgutter", "CodeMirror-lint-markers"]
            };

            if (options.mode === 'text/plain' || elementId.includes('instruction')) {
              options.mode = 'text/plain';
              options.lint = false;
            } else if (options.mode === 'markdown' || elementId.includes('some-markdown-field')) {
              options.mode = 'markdown';
              options.lint = false;
            } else {
              options.mode = { name: "javascript", json: true };
              options.lint = true;
            }

            const cmOptions = Object.assign({}, defaultOptions, options);
            const instance = CodeMirror.fromTextArea(editorElement, cmOptions);

            instance.on('change', function(cm) {
              cm.save();
            });

            window.codeMirrorInstances[elementId] = instance;
            console.log(`CodeMirror initialized successfully for #${elementId}`);

            setTimeout(() => instance.refresh(), 50);

            const observer = new IntersectionObserver((entries) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                       console.log(`CodeMirror instance #${elementId} became visible. Refreshing.`);
                       setTimeout(() => instance.refresh(), 50);
                    }
                });
            }, { threshold: 0.1 });

            observer.observe(instance.getWrapperElement());

          } catch (e) {
            console.error(`Error initializing CodeMirror for #${elementId}:`, e);
            editorElement.style.display = 'block';
          }
        } else if (window.codeMirrorInstances[elementId]) {
          setTimeout(() => {
             if (window.codeMirrorInstances[elementId]) {
                window.codeMirrorInstances[elementId].refresh()
             }
            }, 50);
        }
      }

      function destroyCodeMirrorInstance(elementId) {
        if (window.codeMirrorInstances && window.codeMirrorInstances[elementId]) {
          console.log(`Destroying CodeMirror instance for #${elementId}`);
          try {
            window.codeMirrorInstances[elementId].toTextArea();
          } catch (e) {
            console.error(`Error reverting CodeMirror to textarea for #${elementId}:`, e);
          }
          delete window.codeMirrorInstances[elementId];
        }
      }

      function initializeRelevantEditors(targetElement = document.body) {
        console.log("Scanning for editors to initialize within:", targetElement);
        const editorsToInit = [
          { id: 'mcp_servers_json', options: {} },
          { id: 'instruction', options: { mode: 'text/plain'} },
          { id: 'mcp-json-editor', options: {} },
          { id: 'edit-instruction-textarea', options: { mode: 'text/plain' } },
          { id: 'mcp-json-display', options: { readOnly: true } },
          { id: 'task-json-editor', options: {} },
        ];

        editorsToInit.forEach(editor => {
          if (targetElement && typeof targetElement.querySelector === 'function') {
             const element = targetElement.querySelector(`#${editor.id}`);
             if (element) {
               initCodeMirrorEditor(editor.id, editor.options);
             }
          } else if (!targetElement || targetElement === document.body) {
             const element = document.getElementById(editor.id);
              if (element) {
                initCodeMirrorEditor(editor.id, editor.options);
              }
          }
        });
      }

      document.addEventListener('DOMContentLoaded', () => {
         console.log("DOMContentLoaded: Initializing editors.");
         initializeRelevantEditors(document.body);
         checkServerHealth();
         setInterval(checkServerHealth, 5000);
      });

      document.body.addEventListener('htmx:afterSwap', function(event) {
        console.log("htmx:afterSwap: Initializing editors in swapped content target:", event.detail.target);
        initializeRelevantEditors(event.detail.target);

        const triggerHeader = event.detail.xhr.getResponseHeader('HX-Trigger-After-Swap');
        if (triggerHeader) {
          console.log("Processing HX-Trigger-After-Swap header:", triggerHeader);
          try {
            if (triggerHeader.startsWith('{') && triggerHeader.endsWith('}')) {
               const triggers = JSON.parse(triggerHeader);
               if (triggers.showToast) {
                   showToast(triggers.showToast.message, triggers.showToast.type);
               }
            } else {
              triggerHeader.split(',').forEach(triggerName => {
                triggerName = triggerName.trim();
                if (triggerName === 'showRestartToast') {
                  showToast("Agent automatically restarted to apply changes.", "is-info");
                } else if (triggerName === 'showRestartErrorToast') {
                  showToast("Error: Failed to automatically restart agent. Please stop/start manually.", "is-danger");
                } else if (triggerName === 'showSaveSuccessToast') {
                  showToast("Configuration saved successfully.", "is-success");
                }
              });
            }
          } catch (e) {
             console.error("Error processing HX-Trigger-After-Swap header:", e);
             if (triggerHeader === 'showRestartToast') showToast("Agent automatically restarted.", "is-info");
          }
        }
      });

      document.body.addEventListener('htmx:beforeSwap', function(event) {
          const swapTarget = event.detail.target;
          if (swapTarget && typeof swapTarget.querySelectorAll === 'function') {
             console.log("htmx:beforeSwap: Checking for editors to destroy in target:", swapTarget);
              const textareas = swapTarget.querySelectorAll('textarea');
              textareas.forEach(textarea => {
                  if (textarea.id && window.codeMirrorInstances[textarea.id]) {
                      destroyCodeMirrorInstance(textarea.id);
                  }
              });
          }
          const elt = event.detail.elt;
          if (elt) {
              const targetSelector = elt.getAttribute('hx-target');
              if (targetSelector) {
                  try {
                      let targetElement = null;
                      if (targetSelector === 'this') {
                          targetElement = elt;
                      } else if (targetSelector.startsWith('closest ')) {
                          targetElement = elt.closest(targetSelector.substring(8));
                      } else {
                           targetElement = document.querySelector(targetSelector);
                      }

                      if (targetElement && typeof targetElement.querySelectorAll === 'function') {
                         const textareasInTarget = targetElement.querySelectorAll('textarea');
                          textareasInTarget.forEach(textarea => {
                              if (textarea.id && window.codeMirrorInstances[textarea.id]) {
                                  destroyCodeMirrorInstance(textarea.id);
                              }
                          });
                      }
                  } catch (e) {
                      console.warn("Error finding target element in beforeSwap:", e)
                  }
              }
           }
      });

      document.body.addEventListener('htmx:afterRequest', function(event) {
        const config = event.detail.requestConfig;
        const xhr = event.detail.xhr;
        const elt = config.elt;

        if (elt && elt.id === 'generate-example-task-btn') {
           console.log("htmx:afterRequest from generate button.");
           const editorId = 'task-json-editor';
           const editorInstance = window.codeMirrorInstances[editorId];

           if (!editorInstance) {
               console.error("Task editor CodeMirror instance not found for generate example.");
               showToast("Task editor is not ready. Please wait.", "is-warning");
               return;
           }

           if (event.detail.successful) {
             try {
               const responseJson = xhr.responseText;
               editorInstance.setValue(responseJson);
               console.log("Task editor updated with generated example.");
               showToast("Example task generated.", "is-info", 2000);
             } catch (e) {
               console.error("Error setting value from generate example response:", e);
               showToast("Failed to update task editor with example.", "is-danger");
             }
           } else {
             console.error("Generate example request failed. Status:", xhr.status);
             showToast(`Failed to generate example (Status: ${xhr.status})`, "is-danger");
           }
         }

         const triggerHeader = xhr.getResponseHeader('HX-Trigger-After-Swap');
         if (config.path && config.path.includes('/execute') && triggerHeader && triggerHeader.startsWith('showTaskError')) {
             console.log("htmx:afterRequest from execute task with error trigger:", triggerHeader);
             try {
                 const responseJson = xhr.responseText;
                 const parsedResponse = JSON.parse(responseJson);
                 const errorMessage = parsedResponse?.error || parsedResponse?.message || "An unknown execution error occurred.";
                 const errorHtml =
                   `<div class="notification is-danger is-light mt-3 is-small">
                      <button class="delete" type="button" onclick="this.parentElement.remove();"></button>
                      <strong>Execution Error:</strong><br>
                      <pre style="white-space: pre-wrap; word-break: break-all;">${errorMessage}</pre>
                    </div>`;
                 const targetElement = document.getElementById('task-result');
                 if (targetElement) {
                     targetElement.innerHTML = errorHtml;
                 } else {
                     console.error("Could not find #task-result element to display error.");
                 }
             } catch (e) {
                 console.error("Error parsing error response from /execute:", e);
                 const targetElement = document.getElementById('task-result');
                 if (targetElement) {
                     targetElement.innerHTML = '<div class="notification is-danger is-light mt-3 is-small">Failed to parse error response from server.</div>';
                 }
             }
         }
      });

      function showToast(message, type = 'is-info', duration = 4000) {
          const toastContainer = document.getElementById('toast-container');
          if (!toastContainer) {
              console.error("Toast container not found!");
              return;
          }

          const toast = document.createElement('div');
          toast.className = `notification ${type} is-light`;
          toast.style.marginBottom = '0.5em';
          toast.style.opacity = '0';
          toast.style.transition = 'opacity 0.3s ease-in-out';
          toast.style.boxShadow = '0 2px 5px rgba(0,0,0,0.1)';


          const deleteButton = document.createElement('button');
          deleteButton.className = 'delete';
          deleteButton.type = 'button';
          deleteButton.onclick = () => {
             toast.style.opacity = '0';
             setTimeout(() => toast.remove(), 300);
          };

          toast.appendChild(deleteButton);
          toast.appendChild(document.createTextNode(message));

          toastContainer.appendChild(toast);

          setTimeout(() => toast.style.opacity = '1', 10);

          const timeoutId = setTimeout(() => {
              toast.style.opacity = '0';
              setTimeout(() => toast.remove(), 300);
          }, duration);

          deleteButton.addEventListener('click', () => clearTimeout(timeoutId));
      }

      document.body.addEventListener('click', function(event) {
        if (event.target.matches('.notification > .delete')) {
          if (!event.target.closest('#toast-container')) {
             event.target.parentElement.remove();
          }
        }
      });

      const healthCheckModal = document.getElementById('health-check-modal');
      let isServerUnavailable = false;
      let healthCheckIntervalId = null;

      function checkServerHealth() {
        fetch('/healthz', { method: 'GET', cache: 'no-cache' })
          .then(response => {
            if (!response.ok) {
              throw new Error(`Server status: ${response.status}`);
            }
            if (isServerUnavailable) {
              console.log("Server connection restored.");
              healthCheckModal.classList.remove('is-active');
              isServerUnavailable = false;
              showToast("Server connection restored.", "is-success");
            }
          })
          .catch(error => {
            console.warn("Health check failed:", error.message);
            if (!isServerUnavailable) {
              console.log("Server connection lost. Displaying modal.");
              healthCheckModal.classList.add('is-active');
              isServerUnavailable = true;
            }
          });
      }

      function startHealthCheckPolling() {
          if (healthCheckIntervalId === null) {
              console.log("Starting health check polling.");
              checkServerHealth();
              healthCheckIntervalId = setInterval(checkServerHealth, 5000);
          }
      }

       function stopHealthCheckPolling() {
          if (healthCheckIntervalId !== null) {
              console.log("Stopping health check polling.");
              clearInterval(healthCheckIntervalId);
              healthCheckIntervalId = null;
          }
      }