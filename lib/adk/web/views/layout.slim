    / --- CodeMirror JS --- 
    script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.16/codemirror.min.js"
    script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.16/mode/javascript/javascript.min.js"

    / --- Global CodeMirror Initializer Function & Trigger ---
    javascript:
      function initCodeMirrorEditor(elementId, options = {}) {
        var editorElement = document.getElementById(elementId);
        if (editorElement && !editorElement.cmInstance) {
          console.log("Initializing CodeMirror for", elementId, "with options:", options);
          try {
            // --- Merge default and passed options ---
            var cmOptions = Object.assign({}, {
              lineNumbers: true,
              mode: { name: "javascript", json: true },
              theme: "default"
            }, options);
            // -------------------------------------
            editorElement.cmInstance = CodeMirror.fromTextArea(editorElement, cmOptions);
            editorElement.cmInstance.on('change', function(cm) {
              cm.save(); // Update underlying textarea for HTMX
            });
          } catch (e) {
            console.error("Error initializing CodeMirror:", e);
          }
        } else if (editorElement) {
           console.log("CodeMirror already initialized for", elementId);
        } else {
           console.log("Element not found for CodeMirror init:", elementId);
        }
      }

      // Listen for htmx:load event on the body (for MCP editor)
      document.body.addEventListener('htmx:load', function(event) {
        // Check if the loaded element (event.target) contains the mcp editor
        var mcpEditorElement = event.target.querySelector('#mcp-json-editor');
        if (mcpEditorElement) {
          console.log("htmx:load event detected containing #mcp-json-editor. Triggering init.");
          initCodeMirrorEditor('mcp-json-editor');
        }
      });

      // Listener for Generate Example Button Response AND Execute Task Errors
      document.body.addEventListener('htmx:afterRequest', function(event) {
        // Check if the event was triggered by the Generate Example button
        if (event.detail.requestConfig.elt.id === 'generate-example-task-btn') {
          console.log("htmx:afterRequest event from generate button.");
          if (event.detail.successful) {
            // --- Ensure editor is initialized FIRST ---
            initCodeMirrorEditor('task-json-editor'); 
            // ----------------------------------------
            try {
              var responseJson = event.detail.xhr.responseText;
              var parsedResponse = JSON.parse(responseJson);
              if (parsedResponse && !parsedResponse.error) {
                var taskEditorInstance = document.getElementById('task-json-editor')?.cmInstance;
                if (taskEditorInstance) {
                   // Use responseJson directly as it's already pretty-printed by the server
                   taskEditorInstance.setValue(responseJson); 
                   console.log("Task editor updated with generated example.");
                } else {
                   console.error("Task editor CodeMirror instance not found.");
                   alert("Could not find the task editor to update.");
                }
              } else {
                console.error("Error received from generate example endpoint:", parsedResponse?.error);
                alert("Failed to generate example: " + (parsedResponse?.error || "Unknown error"));
              }
            } catch (e) {
              console.error("Error parsing generate example response:", e);
              alert("Failed to parse example response from server.");
            }
          } else {
            console.error("Generate example request failed. Status:", event.detail.xhr.status);
            alert("Failed to generate example. Server returned status " + event.detail.xhr.status);
          }
        }
        
        // Check if the event was triggered by the Execute Task Form (by URL)
        // AND if it has the custom error event trigger header
        var triggerHeader = event.detail.xhr.getResponseHeader('HX-Trigger-After-Swap');
        if (event.detail.requestConfig.path.includes('/execute') && triggerHeader && triggerHeader.startsWith('showTask')) {
            console.log("htmx:afterRequest event from execute task with error trigger:", triggerHeader);
            try {
                var responseJson = event.detail.xhr.responseText;
                var parsedResponse = JSON.parse(responseJson);
                var errorMessage = parsedResponse?.error || "An unknown error occurred.";
                var errorHtml = 
                  `<div class="notification is-danger is-light mt-4">
                     <button class="delete" onclick="this.parentElement.remove();"></button>
                     ${errorMessage}
                   </div>`;
                var targetElement = document.getElementById('task-result');
                if (targetElement) {
                    targetElement.innerHTML = errorHtml;
                } else {
                    console.error("Could not find #task-result element to display error.");
                }
            } catch (e) {
                console.error("Error parsing error response from /execute:", e);
                var targetElement = document.getElementById('task-result');
                if (targetElement) {
                    targetElement.innerHTML = '<div class="notification is-danger">Failed to parse error response from server.</div>';
                }
            }
        }
      });

      // --- Listener for HX-Trigger-After-Swap header to show toasts ---
      document.body.addEventListener('htmx:afterSwap', function(event) {
        console.log("LAYOUT SCRIPT: htmx:afterSwap detected."); // DEBUG
        var triggerHeader = event.detail.xhr.getResponseHeader('HX-Trigger-After-Swap');
        console.log("LAYOUT SCRIPT: HX-Trigger-After-Swap header:", triggerHeader); // DEBUG
        if (triggerHeader) {
          // Potentially dispatch custom events or call functions based on header value
          if (triggerHeader === 'showRestartToast') {
            console.log("LAYOUT SCRIPT: Triggering showToast for success..."); // DEBUG
            showToast("Agent automatically restarted to apply changes.", "is-info");
          } else if (triggerHeader === 'showRestartErrorToast') {
            console.log("LAYOUT SCRIPT: Triggering showToast for error..."); // DEBUG
            showToast("Error: Failed to automatically restart agent. Please stop/start manually.", "is-danger");
          }
        }

        // --- MODIFIED: Check for both MCP editor and display textareas after swap ---
        var mcpEditorElement = event.target.querySelector('#mcp-json-editor');
        var mcpDisplayElement = event.target.querySelector('#mcp-json-display');
        
        if (mcpEditorElement) {
          console.log("htmx:afterSwap event detected containing #mcp-json-editor. Triggering init.");
          initCodeMirrorEditor('mcp-json-editor'); // Initialize editable editor
        }
        if (mcpDisplayElement) {
          console.log("htmx:afterSwap event detected containing #mcp-json-display. Triggering init.");
          initCodeMirrorEditor('mcp-json-display', { readOnly: true }); // Initialize read-only display editor
        }
        // --- END MODIFICATION ---
      });
      
      // --- Toast Notification Function ---
      function showToast(message, type = 'is-info', duration = 4000) {
          var toastContainer = document.getElementById('toast-container');
          if (!toastContainer) { // Create container if it doesn't exist
              toastContainer = document.createElement('div');
              toastContainer.id = 'toast-container';
              // Add styles inline or via CSS for positioning (e.g., top-right)
              toastContainer.style.position = 'fixed';
              toastContainer.style.top = '1em';
              toastContainer.style.right = '1em';
              toastContainer.style.zIndex = '9999'; 
              document.body.appendChild(toastContainer);
          }

          var toast = document.createElement('div');
          toast.className = `notification ${type} is-light`;
          toast.style.marginBottom = '0.5em'; // Spacing between toasts
          toast.innerHTML = `
              <button class="delete" onclick="this.parentElement.remove();"></button>
              ${message}
          `;
          
          toastContainer.appendChild(toast);

          // Automatically remove the toast after duration
          setTimeout(() => {
              toast.remove();
          }, duration);
      }

      // Initialize Task Editor on initial page load
      document.addEventListener('DOMContentLoaded', function() {
         console.log("LAYOUT SCRIPT: DOMContentLoaded fired. Initializing task editor...");
         initCodeMirrorEditor('task-json-editor');
         // --- ADDED: Initialize MCP Editor on initial page load (agent create form) ---
         console.log("LAYOUT SCRIPT: Initializing MCP editor (create form)...");
         initCodeMirrorEditor('mcp_servers_json');
         // --- ADDED: Initialize MCP display editor (agent detail view) ---
         console.log("LAYOUT SCRIPT: Initializing MCP editor (display)...");
         initCodeMirrorEditor('mcp-json-display', { readOnly: true });
         // --------------------------------------------------------------------------
      });

      // --- Add listener for notification close buttons ---
      document.body.addEventListener('click', function(event) {
        if (event.target.matches('.notification > .delete')) {
          event.target.parentElement.remove();
        }
      });

      // -------- NEW: Health Check Polling --------
      const healthCheckModal = document.getElementById('health-check-modal');
      let isServerUnavailable = false;

      function checkServerHealth() {
        fetch('/healthz')
          .then(response => {
            if (!response.ok) {
              // Throw an error to be caught by the catch block
              throw new Error(`Server status: ${response.status}`);
            }
            // Server is OK
            if (isServerUnavailable) {
              console.log("Server connection restored.");
              healthCheckModal.classList.remove('is-active');
              isServerUnavailable = false;
            }
          })
          .catch(error => {
            // Server is down or fetch failed
            console.warn("Health check failed:", error.message);
            if (!isServerUnavailable) {
              console.log("Server connection lost. Displaying modal.");
              healthCheckModal.classList.add('is-active');
              isServerUnavailable = true;
            }
          });
      }

      // Check immediately on load
      checkServerHealth();
      // Then check every 5 seconds
      setInterval(checkServerHealth, 5000);
      // -------- END: Health Check Polling --------

    / --- Custom Scripts (if any) ---
    / script src="/js/app.js"