#!/usr/bin/env ruby
# frozen_string_literal: true

# Add lib to load path
lib = File.expand_path('../lib', __dir__)
$LOAD_PATH.unshift(lib) unless $LOAD_PATH.include?(lib)

require 'adk'
ADK.load_environment

begin
  require 'pry'
  IRB = Pry
rescue LoadError
  require 'irb'
  require 'irb/completion'
end

puts "Loaded ADK v#{ADK::VERSION}"
IRB.start
