# ADK Configuration
RACK_ENV=development
ADK_LOG_LEVEL=DEBUG

# Redis Connection
REDIS_URL=redis://localhost:6379/0

# LLM Configuration
# Note: Code expects GOOGLE_API_KEY, although docs may mention GEMINI_API_KEY
GOOGLE_API_KEY=your_google_api_key_here

# Security Secrets
WEBHOOK_RECEIVER_SECRET=your_webhook_secret
SESSION_SECRET=your_session_secret
