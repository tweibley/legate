# Legate Environment Configuration
# Copy this file to .env and fill in your values

# Required: Google Gemini API key for LLM planning
GOOGLE_API_KEY=your_gemini_api_key_here

# Optional: Log level (DEBUG, INFO, WARN, ERROR, FATAL, NONE)
LEGATE_LOG_LEVEL=DEBUG

# Optional: Environment (development, production)
RACK_ENV=development

# Required in production: Session cookie secret
# SESSION_SECRET=generate_a_secure_random_string_here
