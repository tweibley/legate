# ADK Ruby Environment Configuration

# Environment mode (development|production)
RACK_ENV=development

# Logging level (DEBUG|INFO|WARN|ERROR)
ADK_LOG_LEVEL=DEBUG

# Redis connection URL
REDIS_URL=redis://localhost:6379/0

# Gemini API Key (Required for Planner and AI generators)
# Get one at https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_gemini_api_key_here
# GEMINI_API_KEY= # Alias for GOOGLE_API_KEY if preferred

# Web UI Session Secret (Required for production, optional for dev)
SESSION_SECRET=change_me_in_production

# Webhook Secret (Required for webhook verification)
WEBHOOK_SECRET=your_webhook_secret_here
