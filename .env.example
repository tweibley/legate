# Environment Configuration
# Copy this file to .env and customize as needed.

# Application Environment (development, production, test)
RACK_ENV=development

# Logging Level (DEBUG, INFO, WARN, ERROR, FATAL, NONE)
ADK_LOG_LEVEL=DEBUG

# Redis Connection URL
# Used for session storage, Sidekiq background jobs, and agent definition storage.
REDIS_URL=redis://localhost:6379/0

# Google Gemini API Key
# Required for the default ADK::Planner to generate execution plans.
# Get one at: https://aistudio.google.com/
GOOGLE_API_KEY=your_gemini_api_key_here

# Webhook Security
# Secret key used to verify signatures of incoming webhooks.
WEBHOOK_RECEIVER_SECRET=your_webhook_secret_here

# Web UI Session Secret
# Secret used to sign session cookies in the Web UI.
SESSION_SECRET=your_session_secret_here
