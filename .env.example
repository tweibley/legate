# ADK Ruby Configuration

# Environment mode (development/production)
RACK_ENV=development

# Logging level (DEBUG, INFO, WARN, ERROR, FATAL, NONE)
# Defaults to DEBUG in development, WARN otherwise
ADK_LOG_LEVEL=DEBUG

# Redis connection URL (Required for Session persistence and Sidekiq)
# Use valkey or redis
REDIS_URL=redis://localhost:6379/0

# Google API Key for Gemini Planner (Required for AI planning)
# Get one at https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here
# GOOGLE_API_KEY=your_google_api_key_here # Alias for GEMINI_API_KEY

# Web UI Session Secret (Random string for secure sessions)
SESSION_SECRET=change_me_to_a_secure_random_string

# Sidekiq Webhook Receiver Secret (For verifying inbound webhooks)
WEBHOOK_RECEIVER_SECRET=change_me_to_a_secure_random_string
